# ============================================================
# 水转大纺车系统环境变量
# 可通过 docker-compose 自动加载
# ============================================================

# ---------- 全局 ----------
COMPOSE_PROJECT_NAME=spinning-wheel
TZ=Asia/Shanghai

# ---------- InfluxDB ----------
INFLUXDB_VERSION=2.7
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=password123
DOCKER_INFLUXDB_INIT_ORG=spinning-org
DOCKER_INFLUXDB_INIT_BUCKET=spinning-bucket
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=spinning-token
INFLUXDB_URL=http://influxdb:8086

# ---------- Redis ----------
REDIS_VERSION=7.2-alpine
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Mosquitto ----------
MOSQUITTO_VERSION=2.0
MQTT_HOST=mosquitto
MQTT_PORT=1883

# ---------- Nginx ----------
NGINX_VERSION=1.25-alpine
NGINX_PORT=80

# ---------- FastAPI 网关 ----------
API_GATEWAY_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=600

# ---------- 模拟器 ----------
SIMULATOR_WATER_MODE=stable
SIMULATOR_YARN_SPEC=cotton_20s
SIMULATOR_MODBUS_HOST=0.0.0.0
SIMULATOR_MODBUS_PORT=5020
SIMULATOR_REPORT_INTERVAL=60

# ---------- Modbus 采集 ----------
MODBUS_HOST=simulator
MODBUS_PORT=5020
MODBUS_SLAVE_ID=1
MODBUS_POLL_INTERVAL=0.5

# ---------- 配置文件路径 ----------
SPINNING_CONFIG_PATH=/app/config.yaml
